{
  "name": "@neo-cheems/mienvio-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Mienvío API v2 — ship packages across Mexico",
  "type": "module",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun run scripts/build.ts",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --apply src/ tests/",
    "format": "biome format --write src/ tests/",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run lint && bun run test"
  },
  "keywords": [
    "mienvio",
    "neo-cheems",
    "shipping",
    "mexico",
    "parcel",
    "api",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tesuser4444/MiEnvioSDK"
  },
  "bugs": {
    "url": "https://github.com/tesuser4444/MiEnvioSDK/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
